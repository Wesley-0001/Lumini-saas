rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // ─────────────────────────────────────────────────────────────
    // Cross-Resource Validation (sem Custom Claims / sem backend)
    // Fonte de verdade: /users/$(request.auth.uid)
    // ─────────────────────────────────────────────────────────────
    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasUserData() {
      return signedIn() && exists(userPath());
    }

    function getUserData() {
      return hasUserData() ? get(userPath()).data : null;
    }

    function userRole() {
      return hasUserData() && getUserData().role != null
        ? getUserData().role
        : '';
    }

    function userTeamId() {
      return hasUserData() && getUserData().teamId != null
        ? getUserData().teamId
        : null;
    }

    function isAdmin() {
      return signedIn() && userRole() == 'admin';
    }

    function teamMatchesDoc(data) {
      return signedIn()
        && data.teamId != null
        && userTeamId() != null
        && data.teamId == userTeamId();
    }

    // ─────────────────────────────────────────────────────────────
    // daily_attendance (frequência por equipe)
    // Leitura: somente autenticados e dentro do escopo da equipe (ou admin-like).
    // Escrita: admin-like OU supervisor dono da equipe.
    // ─────────────────────────────────────────────────────────────
    match /daily_attendance/{docId} {
      allow read: if signedIn() && (isAdmin() || teamMatchesDoc(resource.data));

      allow create: if signedIn() && (
        isAdmin()
        || (
          request.resource.data.teamId != null
          && userTeamId() != null
          && request.resource.data.teamId == userTeamId()
        )
      );

      allow update: if signedIn() && (
        isAdmin()
        || (
          teamMatchesDoc(resource.data)
          && request.resource.data.teamId == resource.data.teamId
          && userTeamId() != null
          && request.resource.data.teamId == userTeamId()
        )
      );

      allow delete: if signedIn() && isAdmin();
    }

    // ─────────────────────────────────────────────────────────────
    // users: modo manutenção — leitura apenas do documento /users/{auth.uid}; sem escrita pelo cliente.
    // ─────────────────────────────────────────────────────────────
    match /users/{uid} {
      // Modo manutenção: lê só o próprio documento por UID (sem cross-validation pesada)
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // ─────────────────────────────────────────────────────────────
    // leaders: (opcional) leitura do próprio time (ou admin); escrita só admin.
    // Útil para setups legados onde "leaders" guarda equipe/escopo.
    // ─────────────────────────────────────────────────────────────
    match /leaders/{leaderId} {
      allow read: if signedIn() && (isAdmin() || (
        userTeamId() != null && leaderId == userTeamId()
      ));
      allow create, update, delete: if signedIn() && isAdmin();
    }

    // Padrão seguro: negar o resto até definir regras por coleção.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

